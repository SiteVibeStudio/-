---
---
<div class="absolute inset-0 z-0 pointer-events-none overflow-hidden flex items-center justify-center">
  <!-- Glowing aura behind text to ensure readability -->
  <div class="absolute w-[800px] h-[800px] bg-white/40 blur-[130px] rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  
  <!-- 3D Golden Ring (Simulated with gradients and borders) -->
  <div class="absolute w-[600px] h-[600px] md:w-[850px] md:h-[850px] rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-25 animate-[spin-slow_30s_linear_infinite]" 
       style="border: 2px solid transparent; border-image: linear-gradient(to bottom right, #D4AF37 0%, transparent 40%, #D4AF37 80%, transparent 100%) 1; border-radius: 50%;"></div>
  
  <div class="absolute w-[650px] h-[650px] md:w-[900px] md:h-[900px] border-[1px] border-[#D4AF37]/20 rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-30 rotate-45 animate-[spin-slow_45s_linear_infinite_reverse]"></div>

  <!-- Floating Elements -->
  
  <!-- Pill object -->
  <div class="absolute top-[20%] right-[10%] md:right-[15%] w-[72px] h-[110px] rotate-[35deg] animate-float-slow">
    <div class="relative w-full h-full shadow-[0_20px_40px_rgba(0,0,0,0.1),inset_0_4px_10px_rgba(255,255,255,0.8)] rounded-full overflow-hidden flex flex-col">
      <!-- White top -->
      <div class="w-full h-1/2 bg-gradient-to-b from-white to-gray-100 flex items-center justify-center pt-2">
        <span class="text-[#E95E4A] font-bold text-2xl leading-none">+</span>
      </div>
      <!-- Red bottom -->
      <div class="w-full h-1/2 bg-gradient-to-b from-[#E95E4A] to-[#c74532] shadow-[inset_0_5px_15px_rgba(0,0,0,0.2)]"></div>
      
      <!-- 3D Shine highlight overlay -->
      <div class="absolute top-2 left-2 w-2 h-16 bg-white/40 rounded-full blur-[2px]"></div>
    </div>
  </div>

  <!-- Golden Sphere Large -->
  <div class="absolute bottom-[20%] left-[12%] md:left-[18%] w-16 h-16 rounded-full bg-gradient-to-br from-[#FFF3CC] via-[#D4AF37] to-[#8C7326] shadow-[0_15px_35px_rgba(212,175,55,0.3),inset_-6px_-6px_15px_rgba(0,0,0,0.4),inset_4px_4px_8px_rgba(255,255,255,0.6)] animate-float-medium"></div>

  <!-- Golden Sphere Small -->
  <div class="absolute top-[28%] left-[15%] md:left-[22%] w-8 h-8 rounded-full bg-gradient-to-br from-[#FFF3CC] via-[#D4AF37] to-[#8C7326] shadow-[0_8px_20px_rgba(212,175,55,0.2),inset_-3px_-3px_8px_rgba(0,0,0,0.4),inset_2px_2px_4px_rgba(255,255,255,0.6)] animate-float-fast delay-700"></div>
  
  <!-- Sleek White Sphere -->
  <div class="absolute bottom-[28%] right-[15%] md:right-[22%] w-10 h-10 rounded-full bg-gradient-to-br from-white via-gray-100 to-gray-300 shadow-[0_10px_25px_rgba(0,0,0,0.08),inset_-4px_-4px_12px_rgba(0,0,0,0.15)] animate-float-slow delay-1000"></div>
</div>

<style>
  @keyframes spin-slow {
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes float-slow {
    0%, 100% { transform: translateY(0) rotate(35deg); }
    50% { transform: translateY(-30px) rotate(45deg); }
  }
  @keyframes float-medium {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-25px) scale(1.02); }
  }
  @keyframes float-fast {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-float-slow { animation: float-slow 7s ease-in-out infinite; }
  .animate-float-medium { animation: float-medium 5s ease-in-out infinite; }
  .animate-float-fast { animation: float-fast 3.5s ease-in-out infinite; }
</style>
