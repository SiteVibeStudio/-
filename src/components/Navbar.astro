---
<header class="w-full py-6 flex items-center justify-between z-40 relative">
  <!-- Logo -->
  <div class="flex items-center gap-2">
    <!-- Asterisk/Snowflake Icon -->
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-black">
      <path d="M12 2L12 22M2 12L22 12M4.92893 4.92893L19.0711 19.0711M4.92893 19.0711L19.0711 4.92893" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
    <span class="font-extrabold text-[22px] tracking-tight text-[#0D0D0D]">Future Clinic</span>
  </div>

  <!-- Links -->
  <nav class="hidden md:flex items-center gap-10">
    <a href="#" class="text-[16px] font-medium text-gray-600 hover:text-black transition-colors rounded-full focus:outline-none focus:ring-2 focus:ring-[#E95E4A]/50 px-2 py-1">Home</a>
    <a href="#" class="text-[16px] font-medium text-gray-600 hover:text-black transition-colors rounded-full focus:outline-none focus:ring-2 focus:ring-[#E95E4A]/50 px-2 py-1">About</a>
    <a href="#" class="text-[16px] font-medium text-gray-600 hover:text-black transition-colors rounded-full focus:outline-none focus:ring-2 focus:ring-[#E95E4A]/50 px-2 py-1">Product</a>
  </nav>

  <!-- CTA -->
  <div>
    <a href="#" class="inline-flex items-center justify-center px-7 py-3 bg-white text-[#0D0D0D] text-[15px] font-bold rounded-full border border-gray-200/50 shadow-[0_4px_16px_rgba(0,0,0,0.04)] hover:shadow-[0_6px_20px_rgba(0,0,0,0.08)] hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#E95E4A]/50">
      Sign up
    </a>
  </div>
</header>
