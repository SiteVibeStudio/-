---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import VisualElements from '../components/VisualElements.astro';
---

<Layout title="Future Clinic | Healthcare Redefined" description="Healthcare used to be about doctors and patients. Launch your clinic today.">
  <div class="relative w-full overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 relative z-10 flex flex-col min-h-screen">
      <Navbar />
      <div class="flex-grow flex items-center justify-center relative w-full mt-10 md:mt-0 pb-16">
         <VisualElements />
         <Hero />
      </div>
    </div>
  </div>
</Layout>
